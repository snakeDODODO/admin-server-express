{
  "name": "admin-server-express",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "npm run lint && npm audit",
    "start": "node ./bin/www",
    "devstart": "nodemon ./bin/www",
    "package": "pkg . --out-path dist"
  },
  "dependencies": {
    "@sequelize/core": "^7.0.0-alpha.27",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "debug": "~2.6.9",
    "express": "~4.16.1",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^8.5.1",
    "moment": "^2.30.1",
    "mongoose": "^6.11.3",
    "morgan": "~1.9.1",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.5.2",
    "uuid": "^11.1.0",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "scripts": "bin/www",
    "assets": [
      "public/**/*",
      "views/**/*"
    ],
    "outputPath": "dist"
  }
}
